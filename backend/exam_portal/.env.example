# Copy this file to .env and fill values.
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows CMD)

# Required for AI Scan (OMR image + student details). Get a key from Google AI Studio.
GEMINI_API_KEY=

# Optional: Poppler bin folder on Windows — needed for Bulk PDF upload (pdf2image).
# Install: https://github.com/oschwartz10612/poppler-windows/releases
# POPPLER_PATH=C:\\poppler\\Library\\bin

# Optional — production
# DJANGO_SECRET_KEY=change-this-to-a-long-random-string
# DJANGO_DEBUG=False
